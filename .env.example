# Backend / Vercel serverless functions (api/*.js)
# Copy to .env for local dev, and set these as Environment Variables
# in the Vercel project dashboard for production/preview deployments.

# PostgreSQL connection string (e.g. Neon, Supabase Postgres, RDS...)
# Required for /api/cameras, /api/incidents, /api/search to work.
DATABASE_URL=postgres://user:password@host:5432/dbname

# Supabase project JWT secret (Settings -> API -> JWT Secret in the
# Supabase dashboard). Required as of Phase 1: api/_auth.js verifies
# every request's Authorization: Bearer <token> against this secret.
# NOTE: only works for Supabase projects still using the legacy HS256
# JWT secret. Newer Supabase projects sign with asymmetric keys (RS256/
# ES256) and need JWKS-based verification instead -- not yet supported.
SUPABASE_JWT_SECRET=

# PayPal (server-side)
PAYPAL_ENVIRONMENT=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# Optional overrides:
# PAYPAL_LIVE_CLIENT_ID=
# PAYPAL_LIVE_CLIENT_SECRET=
# PAYPAL_BASE_URL=
