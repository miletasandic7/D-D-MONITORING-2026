# Backend / Vercel serverless functions (api/*.js)
# Copy to .env for local dev, and set these as Environment Variables
# in the Vercel project dashboard for production/preview deployments.

# PostgreSQL connection string (e.g. Neon, Supabase Postgres, RDS...)
# Required for /api/cameras, /api/incidents, /api/search to work.
DATABASE_URL=postgres://user:password@host:5432/dbname

# Supabase project JWT secret (Settings -> API -> JWT Secret in the
# Supabase dashboard). Required as of Phase 1: api/_auth.js verifies
# every request's Authorization: Bearer <token> against this secret.
# NOTE: only works for Supabase projects still using the legacy HS256
# JWT secret. Newer Supabase projects sign with asymmetric keys (RS256/
# ES256) and need JWKS-based verification instead -- not yet supported.
SUPABASE_JWT_SECRET=

# Object storage for snapshots/recordings (Phase 3). S3-compatible:
# works with AWS S3, Cloudflare R2, Backblaze B2, or self-hosted MinIO.
# STORAGE_ENDPOINT: omit entirely for real AWS S3; required for R2/MinIO/etc.
STORAGE_ENDPOINT=
STORAGE_REGION=us-east-1
STORAGE_BUCKET=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_PUBLIC_BASE_URL=

# Recording worker (workers/recording-worker.js) -- a persistent
# process, NOT a Vercel serverless function; run it alongside your
# MediaMTX media server. Seconds to record per triggered event.
RECORDING_DURATION_SECONDS=15

# Media node registry (Phase 5) -- how stale a node's last heartbeat
# can be before it's treated as offline and skipped when assigning
# new cameras.
MEDIA_NODE_HEARTBEAT_FRESHNESS_SECONDS=90

# PayPal (server-side)
PAYPAL_ENVIRONMENT=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# Optional overrides:
# PAYPAL_LIVE_CLIENT_ID=
# PAYPAL_LIVE_CLIENT_SECRET=
# PAYPAL_BASE_URL=
