# Backend / Vercel serverless functions (api/*.js)
# Copy to .env for local dev, and set these as Environment Variables
# in the Vercel project dashboard for production/preview deployments.

# PostgreSQL connection string (e.g. Neon, Supabase Postgres, RDS...)
# Required for /api/cameras, /api/incidents, /api/search to work.
DATABASE_URL=postgres://user:password@host:5432/dbname

# PayPal (server-side)
PAYPAL_ENVIRONMENT=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# Optional overrides:
# PAYPAL_LIVE_CLIENT_ID=
# PAYPAL_LIVE_CLIENT_SECRET=
# PAYPAL_BASE_URL=
