# Frontend (Vite) environment variables.
# Copy to frontend/.env.local for local dev. In Vercel, set these as
# Environment Variables scoped to the frontend build.
# All must be prefixed with VITE_ to be exposed to the browser bundle.

# Supabase project (used for authentication/login only — camera and
# incident DATA come from /api, not Supabase, in this project).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Base path for REST API calls. Defaults to "/api" (same-origin, Vercel
# serverless functions). Only change this if the API is hosted elsewhere.
VITE_API_BASE_URL=/api

# Base URL where HLS manifests are served, one folder per camera id:
#   {VITE_HLS_BASE_URL}/{cameraId}/index.m3u8
#
# IMPORTANT: Vercel serverless functions CANNOT run a persistent RTSP->HLS
# transcoder. This must point to an externally hosted, always-on media
# server (e.g. MediaMTX / go2rtc) that ingests each camera's RTSP feed and
# republishes it as HLS. See /media-server in this repo for a ready-to-run
# MediaMTX config. Example once deployed:
VITE_HLS_BASE_URL=https://your-media-server.example.com/hls

# PayPal (client-side)
VITE_PAYPAL_CLIENT_ID=
VITE_PAYPAL_CURRENCY=USD
